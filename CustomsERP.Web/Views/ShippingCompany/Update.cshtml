@model CustomsERP.Core.ShippingCompany

<h1>Update Shipping Company</h1>

<form method="post" asp-action="Update" asp-route-id="@Model.Id">
    <div asp-validation-summary="All" class="text-danger">
    
        <input type="hidden" asp-for="Id"/>
        <table class="table">
            <thead>
            <tr>
                <th>Name</th>
                <th>Address</th>
                <th>City</th>
                <th>Bank Details</th>
            </tr>
            </thead>
            <tbody>
            <tr>
                <td><input asp-for="Name"/></td>
                <td><input asp-for="Address"/></td>
                <td><input asp-for="City"/></td>
                <td><input asp-for="BankDetails"/></td>
            </tr>
            </tbody>
        </table>
        <button type="submit">Save</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}