@model CustomsERP.Core.Warehouse

<h1>Update Warehouse</h1>

<form method="post" asp-action="Update" asp-route-id="@Model.Id">
    <input type="hidden" asp-for="Id"/>
    <table class="table">
        <thead>
        <tr>
            <th>Warehouse Code</th>
            <th>Name</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td><input asp-for="WarehouseCode"/></td>
            <td><input asp-for="Name"/></td>
        </tr>
        </tbody>
    </table>
    <button type="submit">Save</button>
</form>
